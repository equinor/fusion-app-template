{
  "name": "@equinor/bare",
  "version": "0.0.0",
  "description": "Bare template for building React applications with Fusion Framework. A minimal starting point for developers to create custom applications from scratch.",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "keywords": [
    "fusion-framework",
    "react",
    "typescript",
    "template",
    "equinor",
    "micro-frontend"
  ],
  "scripts": {
    "build": "fusion-framework-cli app build",
    "dev": "fusion-framework-cli app dev",
    "check": "biome check",
    "check:errors": "biome check --diagnostic-level=error",
    "lint": "biome lint",
    "format": "biome format",
    "test:run": "echo \"No tests specified\"",
    "test:coverage": "echo \"No tests specified\"",
    "changeset:version": "pnpm changeset version && pnpm install --lockfile-only && pnpm check:errors --fix",
    "changeset:publish": "pnpm changeset tag"
  },
  "author": "demo@equinor.com",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/equinor/fusion-app-template.git",
    "directory": "apps/bare"
  },
  "bugs": {
    "url": "https://github.com/equinor/fusion-app-template/issues"
  },
  "homepage": "https://equinor.github.io/fusion-framework/",
  "dependencies": {
    "@equinor/fusion-framework-cli": "^14.0.0",
    "@equinor/fusion-framework-react-app": "^10.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
