  "scripts": {
    "build": "fusion-framework-cli app build",
    "dev": "fusion-framework-cli app dev",
    "check": "biome check",
    "check:errors": "biome check --diagnostic-level=error",
    "lint": "biome lint",
    "format": "biome format",
    "test:run": "echo \"No tests specified\"",
    "test:coverage": "echo \"No tests specified\"",
    "changeset:version": "pnpm changeset version && pnpm install --lockfile-only && pnpm check:errors --fix",
    "changeset:publish": "pnpm changeset tag"
  },
  "author": "demo@equinor.com",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/equinor/fusion-app-template.git",
