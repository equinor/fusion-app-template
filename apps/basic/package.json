  "description": "Basic template for building React applications with Fusion Framework. Includes context, navigation, and EDS components.",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "keywords": [
    "fusion-framework",
    "react",
    "typescript",
    "template",
    "equinor",
    "micro-frontend",
    "context",
    "navigation",
    "eds"
