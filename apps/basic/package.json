  },
  "homepage": "https://equinor.github.io/fusion-framework/",
  "dependencies": {
    "@equinor/eds-core-react": "^2.3.7",
    "@equinor/eds-icons": "^1.3.0",
    "@equinor/eds-tokens": "^2.2.0",
    "@equinor/fusion-framework-cli": "next",
    "@equinor/fusion-framework-module-http": "next",
    "@equinor/fusion-framework-module-navigation": "next",
    "@equinor/fusion-framework-react-ag-grid": "next",
    "@equinor/fusion-framework-react-app": "next",
